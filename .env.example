# Copy to .env and replace every <required-...> marker. This file intentionally
# contains no usable production credential.
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=1
MONITORING_TOKEN=<required-random-monitoring-token-at-least-32-characters>

# Production Compose database bootstrap. These values must match the passwords
# encoded in the three role URLs below. Percent-encode reserved URL characters.
POSTGRES_ADMIN_PASSWORD=<required-random-postgres-admin-password>
POSTGRES_MIGRATION_PASSWORD=<required-random-migration-role-password>
POSTGRES_RUNTIME_PASSWORD=<required-random-runtime-role-password>
POSTGRES_MAINTENANCE_PASSWORD=<required-random-maintenance-role-password>
DATABASE_URL=postgresql://wx_runtime:<required-url-encoded-runtime-password>@postgres:5432/wx_upload
MIGRATION_DATABASE_URL=postgresql://wx_migrate:<required-url-encoded-migration-password>@postgres:5432/wx_upload
MAINTENANCE_DATABASE_URL=postgresql://wx_maintenance:<required-url-encoded-maintenance-password>@postgres:5432/wx_upload
DATABASE_RUNTIME_ROLE=wx_runtime
DATABASE_MAINTENANCE_ROLE=wx_maintenance

WECHAT_AUTH_MODE=real
WECHAT_APP_ID=<required-wechat-app-id>
WECHAT_APP_SECRET=<required-wechat-app-secret>
WECHAT_CODE2SESSION_ENDPOINT=https://api.weixin.qq.com/sns/jscode2session

# A matching Ed25519 PKCS#8 private key and SPKI public key in PEM form.
# Docker Compose .env supports single-quoted multi-line values.
JWT_PRIVATE_KEY='<required-ed25519-pkcs8-private-key-pem>'
JWT_PUBLIC_KEY='<required-ed25519-spki-public-key-pem>'
# Base64url without padding; decoded value must contain at least 32 random bytes.
CURSOR_SIGNING_KEY=<required-random-base64url-cursor-signing-key>

R2_ENDPOINT=https://<required-cloudflare-account-id>.r2.cloudflarestorage.com
R2_BUCKET=<required-private-r2-bucket-name>
R2_ACCESS_KEY_ID=<required-bucket-scoped-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<required-bucket-scoped-r2-secret-access-key>
R2_FORCE_PATH_STYLE=false

# Host paths mounted read-only into Nginx.
TLS_CERTIFICATE_FILE=<required-absolute-path-to-fullchain-pem>
TLS_PRIVATE_KEY_FILE=<required-absolute-path-to-private-key-pem>
HTTPS_PORT=443

# GitHub Actions injects these values during automatic deployment. For a manual
# deployment, use the private GHCR package and a full 40-character commit SHA.
API_IMAGE=ghcr.io/<required-github-owner>/<required-repository-name>-api
IMAGE_TAG=<required-40-character-git-commit-sha>
POSTGRES_IMAGE=ghcr.io/<required-github-owner>/<required-repository-name>-api:postgres-<required-40-character-git-commit-sha>
NGINX_IMAGE=ghcr.io/<required-github-owner>/<required-repository-name>-api:nginx-<required-40-character-git-commit-sha>

# Build-time mini-program config; must be the HTTPS origin registered in WeChat.
PUBLIC_API_BASE_URL=https://<required-api-domain>

# Optional local host-port overrides used only by deploy/docker-compose.yml.
POSTGRES_HOST_PORT=55432
MINIO_API_HOST_PORT=59000
MINIO_CONSOLE_HOST_PORT=59001
