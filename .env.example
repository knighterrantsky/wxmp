# Local development only. Replace every value for production deployments.
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
TRUST_PROXY=false
MONITORING_TOKEN=replace-with-random-monitoring-token

# Each process receives only the database URL for its own role.
DATABASE_URL=postgresql://wx_runtime:wx_runtime_local@127.0.0.1:55432/wx_upload
MIGRATION_DATABASE_URL=postgresql://wx_migrate:wx_migrate_local@127.0.0.1:55432/wx_upload
MAINTENANCE_DATABASE_URL=postgresql://wx_maintenance:wx_maintenance_local@127.0.0.1:55432/wx_upload
DATABASE_RUNTIME_ROLE=wx_runtime
DATABASE_MAINTENANCE_ROLE=wx_maintenance

WECHAT_AUTH_MODE=stub
WECHAT_APP_ID=example-app-id
WECHAT_APP_SECRET=example-app-secret
WECHAT_CODE2SESSION_ENDPOINT=https://api.weixin.qq.com/sns/jscode2session

# Development-only temporary signing keys; production rejects this marker.
JWT_PRIVATE_KEY=temporary-development-key
JWT_PUBLIC_KEY=temporary-development-key

R2_ENDPOINT=http://127.0.0.1:59000
R2_BUCKET=wx-private-media
R2_ACCESS_KEY_ID=minio_local
R2_SECRET_ACCESS_KEY=minio_local_secret
R2_FORCE_PATH_STYLE=true
