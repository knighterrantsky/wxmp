{
  "name": "@wx-upload/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node --input-type=module --eval \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:r2:smoke": "vitest run test/integration/r2-smoke.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "pnpm build && node dist/db/migrate.js",
    "db:maintenance": "pnpm build && node dist/maintenance.js",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1086.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "11.1.0",
    "@wx-upload/contracts": "workspace:*",
    "fastify": "5.10.0",
    "pg": "8.16.3",
    "pino": "10.3.1",
    "prom-client": "15.1.3"
  },
  "devDependencies": {
    "@types/pg": "8.15.6"
  }
}
