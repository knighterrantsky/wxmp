page {
  min-height: 100%;
  background: #f3f6f4;
  color: #18332b;
}

.page-shell {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 28rpx 64rpx;
}

.hero-card,
.card {
  box-sizing: border-box;
  border: 1rpx solid rgba(28, 74, 59, 0.1);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(27, 65, 52, 0.07);
}

.hero-card {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  padding: 40rpx 36rpx;
  background: linear-gradient(145deg, #173d32 0%, #28654f 100%);
  color: #ffffff;
}

.eyebrow {
  margin-bottom: 14rpx;
  color: #a9e5c9;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 5rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  line-height: 1.7;
}

.card {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  padding: 34rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 650;
}

.help-text,
.notice-text {
  margin-top: 14rpx;
  color: #61746d;
  font-size: 25rpx;
  line-height: 1.65;
}

form {
  display: flex;
  width: 100%;
  flex-direction: column;
}

.privacy-panel {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 1rpx solid #cbd8d2;
  border-radius: 18rpx;
  background: #f8faf9;
}

.privacy-title {
  font-size: 28rpx;
  font-weight: 650;
}

.privacy-contract-button {
  width: 100%;
  margin-top: 16rpx;
  border: 2rpx solid #1f6b50;
  border-radius: 18rpx;
  background: #ffffff;
  color: #1f6b50;
  font-size: 26rpx;
}

.nickname-input {
  box-sizing: border-box;
  width: 100%;
  height: 92rpx;
  margin-top: 28rpx;
  padding: 0 26rpx;
  border: 2rpx solid #cbd8d2;
  border-radius: 18rpx;
  background: #f8faf9;
  font-size: 29rpx;
}

.nickname-input.compact {
  margin-top: 22rpx;
}

.primary-button,
.secondary-button,
.upload-button {
  width: 100%;
  margin-top: 22rpx;
  border-radius: 18rpx;
  font-size: 29rpx;
  font-weight: 600;
}

.primary-button,
.upload-button {
  background: #1f6b50;
  color: #ffffff;
}

.secondary-button {
  border: 2rpx solid #1f6b50;
  background: #ffffff;
  color: #1f6b50;
}

.privacy-cancel-button {
  width: 100%;
  margin-top: 16rpx;
  border: 0;
  background: transparent;
  color: #61746d;
  font-size: 26rpx;
}

.confirmed-card {
  border-color: rgba(31, 107, 80, 0.22);
}

.confirmed-name {
  margin-top: 16rpx;
  color: #1f6b50;
  font-size: 38rpx;
  font-weight: 700;
}

.upload-card {
  margin-bottom: 0;
}

.upload-button {
  height: 96rpx;
  margin-top: 30rpx;
}

.notice-text {
  color: #9a6c22;
}

.error-text {
  margin-top: 16rpx;
  color: #b3463c;
  font-size: 24rpx;
}

.selection-panel {
  margin-top: 28rpx;
  padding-top: 26rpx;
  border-top: 1rpx solid #e4ebe7;
}

.selection-summary,
.selected-file-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.selection-title {
  color: #18332b;
  font-size: 27rpx;
  font-weight: 650;
}

.selection-total {
  color: #61746d;
  font-size: 24rpx;
}

.selected-file {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f6f9f7;
}

.selected-file-name {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: #18332b;
  font-size: 26rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-file-status {
  margin-left: 20rpx;
  color: #61746d;
  font-size: 22rpx;
}

.status-uploading,
.status-finalizing {
  color: #1f6b50;
}

.status-uploaded {
  color: #14784f;
}

.status-failed {
  color: #b3463c;
}

.selected-file-meta,
.progress-copy {
  display: block;
  margin-top: 10rpx;
  color: #71817b;
  font-size: 22rpx;
}

.progress-track {
  height: 10rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dfe8e3;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #1f6b50 0%, #48a779 100%);
  transition: width 160ms ease-out;
}

.progress-copy {
  text-align: right;
}

.start-upload-button {
  margin-top: 24rpx;
}

.history-button {
  width: 100%;
  margin-top: 22rpx;
  border: 0;
  background: transparent;
  color: #1f6b50;
  font-size: 26rpx;
}
